rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAccountant() {
      return request.auth != null && request.auth.token.isAccountant == true;
    }

    function getUserBusinessId() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.businessId;
    }

    function isBusinessOwner(businessId) {
      return request.auth != null && getUserBusinessId() == businessId;
    }

    match /businesses/{businessId}/invoices/{fileName} {
      allow read: if isBusinessOwner(businessId) || (isAccountant() && fileName.matches('.*\\.pdf'));
      allow write: if isBusinessOwner(businessId);
    }

    match /businesses/{businessId}/uploads/{allPaths=**} {
      allow read, write: if isBusinessOwner(businessId);
    }

    match /exports/{userId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
