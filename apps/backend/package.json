{
  "name": "finlogia-backend",
  "version": "1.0.1",
  "description": "Firebase backend for FinLogia, including Cloud Functions, Firestore rules, and Storage rules.",
  "type": "module",
  "scripts": {
    "setup:office": "bash scripts/setup_office.sh",
    "test:rules": "firebase emulators:exec --only firestore,storage 'vitest run test/rules.test.js'",
    "test:integration": "vitest run functions/test/integration.test.js",
    "prepare": "npx simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "functions/**/*.js": [
      "npm run lint --prefix functions",
      "bash -c 'npm run test --prefix functions'"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "firebase-admin": "^12.1.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "lint-staged": "^15.0.0",
    "simple-git-hooks": "^2.0.0",
    "vitest": "^4.1.2"
  }
}
